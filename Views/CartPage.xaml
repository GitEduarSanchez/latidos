<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Latidos.Views.CartPage"
             Title="Carrito"
             BackgroundColor="#FAFAFA">

    <ContentPage.Resources>
        <Color x:Key="Surface">#FFFFFF</Color>
        <Color x:Key="HairLine">#EFEFEF</Color>
        <Color x:Key="HairLineSoft">#F4F4F4</Color>
        <Color x:Key="TextPrimary">#1A1A1A</Color>
        <Color x:Key="TextSecondary">#6B6B6B</Color>
        <Color x:Key="TextMuted">#A0A0A0</Color>
        <Color x:Key="Accent">#C9A227</Color>
        <Color x:Key="AccentSoft">#FAF4E0</Color>
        <Color x:Key="DangerSoft">#FBE9E7</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="20,16,20,16"
          RowSpacing="16">

        <!-- Header -->
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <VerticalStackLayout Spacing="4">
                <Label Text="Tu carrito"
                       FontSize="30"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource TextPrimary}" />
                <Label Text="{Binding ItemCountText}"
                       FontSize="13"
                       TextColor="{StaticResource TextSecondary}"
                       IsVisible="{Binding HasItems}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1">

            <!-- Empty state -->
            <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                 Spacing="16"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Padding="24">
                <Border WidthRequest="80"
                        HeightRequest="80"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 40"
                        BackgroundColor="{StaticResource AccentSoft}"
                        HorizontalOptions="Center">
                    <Image Source="icon_cart.svg"
                           WidthRequest="34"
                           HeightRequest="34"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <Label Text="A&#250;n no has agregado nada"
                       FontSize="18"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalTextAlignment="Center" />
                <Label Text="Explora los eventos disponibles e inscribe a tus competidores."
                       FontSize="13"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalTextAlignment="Center"
                       MaximumWidthRequest="280"
                       LineBreakMode="WordWrap" />
                <Button Text="Ver eventos"
                        Command="{Binding ContinueShoppingCommand}"
                        BackgroundColor="{StaticResource TextPrimary}"
                        TextColor="White"
                        BorderWidth="0"
                        CornerRadius="12"
                        HeightRequest="48"
                        Padding="22,0"
                        FontFamily="OpenSansSemibold"
                        Margin="0,8,0,0" />
            </VerticalStackLayout>

            <!-- Cart list -->
            <CollectionView ItemsSource="{Binding GroupedCartItems}"
                            IsVisible="{Binding HasItems}"
                            SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="{StaticResource HairLine}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="{StaticResource Surface}"
                                Padding="0">
                            <Border.Shadow>
                                <Shadow Brush="#0A0A0A" Opacity="0.04" Radius="14" Offset="0,4" />
                            </Border.Shadow>
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  RowSpacing="0">

                                <!-- Event header -->
                                <Grid Grid.Row="0"
                                      ColumnDefinitions="64,*"
                                      ColumnSpacing="14"
                                      Padding="16,16,16,12">
                                    <Border WidthRequest="64"
                                            HeightRequest="64"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 14"
                                            BackgroundColor="#EFEFEF">
                                        <Image Source="{Binding EventImageUrl}"
                                               Aspect="AspectFill" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="4"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding EventName}"
                                               FontSize="16"
                                               FontFamily="OpenSansSemibold"
                                               TextColor="{StaticResource TextPrimary}"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation" />
                                        <HorizontalStackLayout Spacing="6">
                                            <Image Source="icon_calendar.svg"
                                                   WidthRequest="12"
                                                   HeightRequest="12"
                                                   Aspect="AspectFit"
                                                   Opacity="0.6" />
                                            <Label Text="{Binding EventDate, StringFormat='{0:dd MMM}'}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>

                                <BoxView Grid.Row="0"
                                         HeightRequest="1"
                                         Color="{StaticResource HairLineSoft}"
                                         Margin="16,0"
                                         VerticalOptions="End" />

                                <!-- Competitors -->
                                <VerticalStackLayout Grid.Row="1"
                                                     Padding="16,4,16,4"
                                                     Spacing="0"
                                                     BindableLayout.ItemsSource="{Binding Items}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="44,*,Auto"
                                                  ColumnSpacing="12"
                                                  Padding="0,10">
                                                <Border WidthRequest="44"
                                                        HeightRequest="44"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 22"
                                                        BackgroundColor="#F4F4F4"
                                                        VerticalOptions="Center">
                                                    <Grid>
                                                        <Label Text="&#129485;"
                                                               FontSize="18"
                                                               TextColor="#B5B5B5"
                                                               HorizontalTextAlignment="Center"
                                                               VerticalTextAlignment="Center" />
                                                        <Image Source="{Binding CompetitorPhotoPath}"
                                                               IsVisible="{Binding HasCompetitorPhoto}"
                                                               Aspect="AspectFill"
                                                               WidthRequest="44"
                                                               HeightRequest="44" />
                                                    </Grid>
                                                </Border>

                                                <VerticalStackLayout Grid.Column="1"
                                                                     Spacing="2"
                                                                     VerticalOptions="Center">
                                                    <Label Text="{Binding CompetitorNameText}"
                                                           FontSize="14"
                                                           FontFamily="OpenSansSemibold"
                                                           TextColor="{StaticResource TextPrimary}"
                                                           MaxLines="1"
                                                           LineBreakMode="TailTruncation" />
                                                    <HorizontalStackLayout Spacing="6">
                                                        <Border Padding="7,2"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 8"
                                                                BackgroundColor="{StaticResource AccentSoft}">
                                                            <Label Text="{Binding CompetitorNumberText}"
                                                                   FontSize="10"
                                                                   FontFamily="OpenSansSemibold"
                                                                   TextColor="{StaticResource Accent}" />
                                                        </Border>
                                                        <Label Text="{Binding CompetitorAgeText}"
                                                               FontSize="11"
                                                               TextColor="{StaticResource TextMuted}"
                                                               VerticalOptions="Center"
                                                               LineBreakMode="TailTruncation" />
                                                    </HorizontalStackLayout>
                                                </VerticalStackLayout>

                                                <HorizontalStackLayout Grid.Column="2"
                                                                       Spacing="6"
                                                                       VerticalOptions="Center">
                                                    <Button Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ChangeCompetitorCommand}"
                                                            CommandParameter="{Binding}"
                                                            BackgroundColor="#F4F4F4"
                                                            BorderWidth="0"
                                                            CornerRadius="10"
                                                            Padding="0"
                                                            HeightRequest="34"
                                                            WidthRequest="34">
                                                        <Button.ImageSource>
                                                            <FileImageSource File="icon_edit.svg" />
                                                        </Button.ImageSource>
                                                    </Button>
                                                    <Button Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveFromCartCommand}"
                                                            CommandParameter="{Binding}"
                                                            BackgroundColor="{StaticResource DangerSoft}"
                                                            BorderWidth="0"
                                                            CornerRadius="10"
                                                            Padding="0"
                                                            HeightRequest="34"
                                                            WidthRequest="34">
                                                        <Button.ImageSource>
                                                            <FileImageSource File="icon_delete.svg" />
                                                        </Button.ImageSource>
                                                    </Button>
                                                </HorizontalStackLayout>
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                                <!-- Footer -->
                                <Grid Grid.Row="2"
                                      ColumnDefinitions="*,Auto"
                                      Padding="16,12,16,16"
                                      ColumnSpacing="12"
                                      BackgroundColor="#FCFCFC">
                                    <HorizontalStackLayout Spacing="6"
                                                           VerticalOptions="Center">
                                        <Image Source="icon_users.svg"
                                               WidthRequest="13"
                                               HeightRequest="13"
                                               Aspect="AspectFit"
                                               Opacity="0.6" />
                                        <Label Text="{Binding CompetitorCountText}"
                                               FontSize="12"
                                               TextColor="{StaticResource TextSecondary}"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>

                                    <Label Grid.Column="1"
                                           Text="{Binding GroupTotalText}"
                                           FontSize="16"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="{StaticResource TextPrimary}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- Bottom checkout bar -->
        <Border Grid.Row="2"
                IsVisible="{Binding HasItems}"
                Padding="18,14"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 18"
                BackgroundColor="{StaticResource Surface}">
            <Border.Shadow>
                <Shadow Brush="#0A0A0A" Opacity="0.06" Radius="18" Offset="0,-2" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="14">
                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Total a pagar"
                               FontSize="11"
                               TextColor="{StaticResource TextMuted}"
                               CharacterSpacing="0.6" />
                        <Label Text="{Binding CartTotalText}"
                               FontSize="24"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="Continuar"
                            Command="{Binding ContinueShoppingCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource TextSecondary}"
                            BorderWidth="0"
                            FontSize="13"
                            HeightRequest="40"
                            Padding="10,0"
                            VerticalOptions="Center" />
                </Grid>

                <Button Text="Finalizar compra"
                        Command="{Binding ProceedToCheckoutCommand}"
                        IsEnabled="{Binding CanCheckout}"
                        BackgroundColor="{StaticResource Accent}"
                        TextColor="White"
                        BorderWidth="0"
                        Padding="0,14"
                        FontSize="15"
                        FontFamily="OpenSansSemibold"
                        CornerRadius="14"
                        HeightRequest="54" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
