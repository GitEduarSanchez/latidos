<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Latidos.Views.CartPage"
             Title="Mi Carrito"
             BackgroundColor="#F8F8F8">

    <Grid RowDefinitions="*,Auto" Padding="12" ColumnSpacing="0" RowSpacing="12">
        <!-- Cart Items -->
        <Grid RowDefinitions="Auto,*" ColumnSpacing="0" RowSpacing="12">
            <Label Text="Mi Carrito" FontSize="28" FontAttributes="Bold" TextColor="#D4AF37" />

            <CollectionView Grid.Row="1" ItemsSource="{Binding CartItems}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="0" CornerRadius="12" HasShadow="True" BorderColor="#E8E8E8" BackgroundColor="White">
                            <Grid ColumnDefinitions="*,Auto" Padding="16" ColumnSpacing="12" RowSpacing="8">
                                <!-- Item Details -->
                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnSpacing="0" RowSpacing="6">
                                    <Label Text="{Binding Event.Name}" FontSize="16" FontAttributes="Bold" TextColor="#2d2d2d" />
                                    <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto" ColumnSpacing="20">
                                        <Label Text="{Binding Quantity, StringFormat='Cantidad: {0}'}" FontSize="13" TextColor="#666666" />
                                        <Label Grid.Column="1" Text="{Binding Event.EventDate, StringFormat='{0:dd MMM}'}" FontSize="13" TextColor="#D4AF37" FontAttributes="Bold" />
                                    </Grid>
                                    <Label Grid.Row="2" Text="{Binding TotalPrice, StringFormat='${0:F2}'}" FontSize="16" FontAttributes="Bold" TextColor="#D4AF37" />
                                </Grid>

                                <!-- Remove Button -->
                                <Button Grid.Column="1" Grid.RowSpan="3" Text="✕" BackgroundColor="#FF6B6B" TextColor="White" 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveFromCartCommand}" 
                                        CommandParameter="{Binding}" Padding="8,8" CornerRadius="20" WidthRequest="36" HeightRequest="36" FontSize="14" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- Cart Summary and Checkout -->
        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10" Padding="0,10,0,0">
            <BoxView Color="#E0E0E0" HeightRequest="1" />

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Padding="8,10" ColumnSpacing="10">
                <Label Text="Total:" FontSize="18" FontAttributes="Bold" TextColor="#2d2d2d" />
                <Label Grid.Column="1" Text="{Binding CartTotal, StringFormat='${0:F2}'}" FontSize="18" FontAttributes="Bold" TextColor="#D4AF37" />
            </Grid>

            <Button Grid.Row="2" Text="Ir a Pagar" Command="{Binding ProceedToCheckoutCommand}" 
                    BackgroundColor="#D4AF37" TextColor="White" Padding="15,12" FontSize="14" IsEnabled="{Binding CanCheckout}" CornerRadius="8" />

            <Button Grid.Row="3" Text="Seguir Comprando" Command="{Binding ContinueShoppingCommand}" 
                    BackgroundColor="Transparent" TextColor="#D4AF37" Padding="15,12" BorderWidth="2" BorderColor="#D4AF37" FontSize="14" CornerRadius="8" />
        </Grid>
    </Grid>
</ContentPage>
