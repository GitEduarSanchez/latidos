<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Latidos.ViewModels"
             x:Class="Latidos.Views.AdminTimesPage"
             Title="Tiempos"
             BackgroundColor="#F7F7F5">

    <VerticalStackLayout Padding="16,12" Spacing="12">
        <Label Text="Registro de tiempos"
               FontSize="24"
               FontAttributes="Bold"
               TextColor="#C9A227" />

        <Border Padding="10,0" Stroke="#E8E3D5" StrokeThickness="1" StrokeShape="RoundRectangle 10" BackgroundColor="White">
            <Picker ItemsSource="{Binding Events}"
                    SelectedItem="{Binding SelectedEvent}"
                    ItemDisplayBinding="{Binding Name}"
                    HeightRequest="44" />
        </Border>

        <Label Text="Formato de tiempo: HH:MM:SS"
               FontSize="12"
               TextColor="#767676" />

        <CollectionView ItemsSource="{Binding Rows}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:AdminTimeRow">
                    <Border Padding="10" Stroke="#E8E3D5" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Margin="0,0,0,8">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding CompetitorName}" FontSize="14" FontAttributes="Bold" TextColor="#252525" />
                                <Label Text="{Binding CompetitorDocument}" FontSize="12" TextColor="#777777" />
                                <Label Text="{Binding CompetitorNumber}" FontSize="11" TextColor="#999999" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1" Padding="8,0" Stroke="#E8E3D5" StrokeThickness="1" StrokeShape="RoundRectangle 8" BackgroundColor="#FAFAFA" WidthRequest="110">
                                <Entry Text="{Binding TimeText}" Placeholder="00:00:00" Keyboard="Text" HorizontalTextAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Guardar tiempos"
                Command="{Binding SaveTimesCommand}"
                BackgroundColor="#C9A227"
                TextColor="White"
                FontAttributes="Bold"
                HeightRequest="46"
                CornerRadius="10" />

        <Label Text="{Binding StatusMessage}"
               IsVisible="{Binding HasStatusMessage}"
               FontSize="12"
               TextColor="#4F4F4F" />
    </VerticalStackLayout>
</ContentPage>
