<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Latidos.Views.CheckoutPage"
             Title="Pago"
             BackgroundColor="#F8F8F8">

    <ScrollView Padding="12">
        <VerticalStackLayout Spacing="12">
            <!-- Order Summary -->
            <Frame Padding="16" CornerRadius="12" HasShadow="True" BorderColor="#E8E8E8" BackgroundColor="White">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Resumen del Pedido" FontSize="18" FontAttributes="Bold" TextColor="#D4AF37" />
                    <BoxView Color="#E0E0E0" HeightRequest="1" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Text="Artículos:" FontSize="14" TextColor="#2d2d2d" />
                        <Label Grid.Column="1" Text="{Binding ItemCount}" FontSize="14" FontAttributes="Bold" TextColor="#2d2d2d" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Text="Subtotal:" FontSize="14" TextColor="#2d2d2d" />
                        <Label Grid.Column="1" Text="{Binding Subtotal, StringFormat='${0:F2}'}" FontSize="14" FontAttributes="Bold" TextColor="#2d2d2d" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Text="IVA:" FontSize="14" TextColor="#2d2d2d" />
                        <Label Grid.Column="1" Text="{Binding Tax, StringFormat='${0:F2}'}" FontSize="14" FontAttributes="Bold" TextColor="#2d2d2d" />
                    </Grid>
                    <BoxView Color="#D4AF37" HeightRequest="2" Margin="0,8,0,8" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Text="Total:" FontSize="16" FontAttributes="Bold" TextColor="#D4AF37" />
                        <Label Grid.Column="1" Text="{Binding Total, StringFormat='${0:F2}'}" FontSize="16" FontAttributes="Bold" TextColor="#D4AF37" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Customer Information -->
            <Frame Padding="16" CornerRadius="12" HasShadow="True" BorderColor="#E8E8E8" BackgroundColor="White">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Información Personal" FontSize="18" FontAttributes="Bold" TextColor="#D4AF37" />
                    <Entry Placeholder="Nombre Completo" Text="{Binding CustomerName}" PlaceholderColor="#999999" />
                    <Entry Placeholder="Correo Electrónico" Text="{Binding CustomerEmail}" Keyboard="Email" PlaceholderColor="#999999" />
                </VerticalStackLayout>
            </Frame>

            <!-- Payment Information -->
            <Frame Padding="16" CornerRadius="12" HasShadow="True" BorderColor="#E8E8E8" BackgroundColor="White">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Información de Pago" FontSize="18" FontAttributes="Bold" TextColor="#D4AF37" />
                    <Entry Placeholder="Número de Tarjeta" Text="{Binding CardNumber}" Keyboard="Numeric" MaxLength="16" PlaceholderColor="#999999" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Entry Placeholder="MM/YY" Text="{Binding CardExpiry}" PlaceholderColor="#999999" />
                        <Entry Grid.Column="1" Placeholder="CVV" Text="{Binding CardCvv}" Keyboard="Numeric" MaxLength="3" PlaceholderColor="#999999" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Terms and Conditions -->
            <Frame Padding="16" CornerRadius="12" HasShadow="False" BorderColor="Transparent" BackgroundColor="White">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" RowSpacing="8">
                    <CheckBox IsChecked="{Binding AcceptedTerms}" />
                    <Label Grid.Column="1" Text="Acepto los términos y condiciones" VerticalTextAlignment="Center" FontSize="13" TextColor="#2d2d2d" />
                </Grid>
            </Frame>

            <!-- Process Payment Button -->
            <Button Text="Procesar Pago" Command="{Binding ProcessPaymentCommand}" 
                    BackgroundColor="#D4AF37" TextColor="White" Padding="15,12" FontSize="14" 
                    IsEnabled="{Binding CanProcessPayment}" CornerRadius="8" />

            <!-- Cancel Button -->
            <Button Text="Cancelar" Command="{Binding CancelCommand}" 
                    BackgroundColor="Transparent" TextColor="#D4AF37" Padding="15,12" 
                    BorderWidth="2" BorderColor="#D4AF37" FontSize="14" CornerRadius="8" />

            <!-- Status Message -->
            <Label Text="{Binding StatusMessage}" FontSize="12" TextColor="#FF6B6B" LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
