<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Latidos.Views.EventsPage"
             Title="Eventos">

    <Grid RowDefinitions="Auto,Auto,*"
          Padding="16,12"
          RowSpacing="12"
          BackgroundColor="#F7F7F5">

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <VerticalStackLayout Spacing="2">
                <Label Text="Explora Eventos"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="#C9A227"
                       LineBreakMode="TailTruncation" />
                <Label Text="{Binding EventsCountText}"
                       FontSize="12"
                       TextColor="#767676" />
            </VerticalStackLayout>

            <Border Grid.Column="1"
                    Padding="12,0"
                    HeightRequest="44"
                    Stroke="#C9A227"
                    StrokeThickness="1.2"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="White"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToCartCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="7"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center">
                    <Image Source="icon_cart.svg"
                           WidthRequest="18"
                           HeightRequest="18"
                           Aspect="AspectFit" />
                    <Label Text="Carrito"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#C9A227"
                           VerticalOptions="Center" />
                    <Border IsVisible="{Binding IsCartBadgeVisible}"
                            InputTransparent="True"
                            MinimumWidthRequest="22"
                            HeightRequest="22"
                            Padding="5,0"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 11"
                            BackgroundColor="#252525"
                            VerticalOptions="Center">
                        <Label Text="{Binding CartItemCount}"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Border>
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Padding="12"
                Stroke="#E8E3D5"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 14"
                BackgroundColor="White">
            <VerticalStackLayout Spacing="10">
                <SearchBar Text="{Binding SearchText}"
                           Placeholder="Buscar por nombre"
                           HeightRequest="44"
                           Margin="0" />

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">
                    <Border Padding="10,0"
                            Stroke="#E8E3D5"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="#FAFAFA">
                        <Entry Text="{Binding CitySearchText}"
                               Placeholder="Ciudad o lugar"
                               HeightRequest="44"
                               ClearButtonVisibility="WhileEditing" />
                    </Border>

                    <Button Grid.Column="1"
                            Text="Limpiar"
                            Command="{Binding ClearFiltersCommand}"
                            BackgroundColor="White"
                            TextColor="#C9A227"
                            BorderColor="#C9A227"
                            BorderWidth="1"
                            CornerRadius="10"
                            FontAttributes="Bold"
                            FontSize="12"
                            HeightRequest="44"
                            Padding="14,0" />
                </Grid>

                <Border Padding="10,0"
                        Stroke="#E8E3D5"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="#FAFAFA">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="8"
                          HeightRequest="44">
                        <CheckBox IsChecked="{Binding IsDateFilterEnabled}"
                                  VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="Filtrar por fecha"
                               TextColor="#4F4F4F"
                               FontSize="13"
                               VerticalOptions="Center" />
                        <DatePicker Grid.Column="2"
                                    Date="{Binding FilterDate}"
                                    IsEnabled="{Binding IsDateFilterEnabled}"
                                    Format="dd MMM yyyy"
                                    FontSize="13"
                                    VerticalOptions="Center" />
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Events}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <Grid Padding="24,36">
                    <VerticalStackLayout Spacing="10"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">
                        <Label Text="No se encontraron eventos"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#252525"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Ajusta el nombre, la ciudad o la fecha para ver mas resultados."
                               FontSize="13"
                               TextColor="#767676"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Grid>
            </CollectionView.EmptyView>

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="0"
                           CornerRadius="14"
                           IsClippedToBounds="True"
                           HasShadow="True"
                           BorderColor="#E8E3D5"
                           BackgroundColor="White"
                           Margin="0">
                        <Grid RowDefinitions="148,Auto,Auto,Auto,Auto,Auto"
                              RowSpacing="0">

                            <Grid Grid.Row="0">
                                <Image Source="{Binding ImageUrl}"
                                       Aspect="AspectFill"
                                       HorizontalOptions="Fill"
                                       VerticalOptions="Fill"
                                       HeightRequest="148" />
                                <Border Padding="10,5"
                                        Margin="12"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{Binding StatusBackgroundColor}"
                                        HorizontalOptions="End"
                                        VerticalOptions="Start">
                                    <Label Text="{Binding StatusText}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{Binding StatusTextColor}" />
                                </Border>
                            </Grid>

                            <Label Grid.Row="1"
                                   Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#252525"
                                   Padding="16,14,16,4"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation" />

                            <Label Grid.Row="2"
                                   Text="{Binding Description}"
                                   FontSize="13"
                                   TextColor="#666666"
                                   Padding="16,0,16,12"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2" />

                            <Grid Grid.Row="3"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="16"
                                  Padding="16,0,16,10">
                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                    <Image Source="icon_calendar.svg"
                                           WidthRequest="14"
                                           HeightRequest="14"
                                           Aspect="AspectFit" />
                                    <Label Text="{Binding EventDate, StringFormat='{0:dd MMM}'}"
                                           FontSize="12"
                                           TextColor="#4F4F4F"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Column="1"
                                                       Spacing="6"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="Fill">
                                    <Image Source="icon_location.svg"
                                           WidthRequest="14"
                                           HeightRequest="14"
                                           Aspect="AspectFit" />
                                    <Label Text="{Binding CityLocationText}"
                                           FontSize="12"
                                           TextColor="#747474"
                                           LineBreakMode="TailTruncation"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Fill" />
                                </HorizontalStackLayout>
                            </Grid>

                            <Grid Grid.Row="4"
                                  ColumnDefinitions="*,Auto"
                                  Padding="16,0,16,0">
                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                    <Image Source="icon_tag.svg"
                                           WidthRequest="15"
                                           HeightRequest="15"
                                           Aspect="AspectFit" />
                                    <Label Text="{Binding Price, StringFormat='${0:F2}'}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#C9A227"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Column="1"
                                                       Spacing="6"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="End">
                                    <Image Source="icon_users.svg"
                                           WidthRequest="15"
                                           HeightRequest="15"
                                           Aspect="AspectFit" />
                                    <Label Text="{Binding CurrentParticipants, StringFormat='{0} inscritos'}"
                                           FontSize="12"
                                           TextColor="#747474"
                                           HorizontalTextAlignment="End"
                                           LineBreakMode="TailTruncation"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Grid>

                            <Grid Grid.Row="5"
                                  Margin="16,12,16,16">
                                <Button Text="Inscribir competidor"
                                        ImageSource="icon_cart.svg"
                                        ContentLayout="Left,8"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AddToCartCommand}"
                                        CommandParameter="{Binding}"
                                        IsVisible="{Binding CanRegister}"
                                        BackgroundColor="White"
                                        TextColor="#C9A227"
                                        BorderColor="#C9A227"
                                        BorderWidth="1"
                                        Padding="16,10"
                                        FontSize="13"
                                        FontAttributes="Bold"
                                        CornerRadius="10"
                                        HeightRequest="46" />

                                <Border IsVisible="{Binding IsRegistrationClosed}"
                                        Padding="16,0"
                                        Stroke="#E2E2E2"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="#F6F6F6"
                                        HeightRequest="46">
                                    <Label Text="{Binding RegistrationClosedText}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#777777"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
