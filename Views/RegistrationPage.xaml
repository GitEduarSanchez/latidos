<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Latidos.ViewModels"
             x:Class="Latidos.Views.RegistrationPage"
             Title="Inscripcion"
             BackgroundColor="#F8F7F2">

    <ContentPage.Resources>
        <Color x:Key="Surface">#FFFFFF</Color>
        <Color x:Key="SurfaceSoft">#FBF8F1</Color>
        <Color x:Key="HairLine">#EDE5D6</Color>
        <Color x:Key="TextPrimary">#24211C</Color>
        <Color x:Key="TextSecondary">#756E61</Color>
        <Color x:Key="TextMuted">#A19889</Color>
        <Color x:Key="Accent">#C9A227</Color>
        <Color x:Key="AccentSoft">#FFF5D4</Color>
        <Color x:Key="DangerSoft">#FFF1EF</Color>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Stroke" Value="{StaticResource HairLine}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeShape" Value="RoundRectangle 20" />
            <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="Label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
        </Style>

        <Style x:Key="FieldShell" TargetType="Border">
            <Setter Property="HeightRequest" Value="48" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Stroke" Value="{StaticResource HairLine}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeShape" Value="RoundRectangle 14" />
            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceSoft}" />
        </Style>

        <Style x:Key="FormEntry" TargetType="Entry">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            <Setter Property="PlaceholderColor" Value="#BDB5A7" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="HeightRequest" Value="46" />
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderColor" Value="{StaticResource HairLine}" />
            <Setter Property="BorderWidth" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="HeightRequest" Value="42" />
            <Setter Property="Padding" Value="14,0" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="18,18,18,120"
                                 Spacing="14">

                <VerticalStackLayout Spacing="3">
                    <Label Text="Ficha del competidor"
                           FontSize="26"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label Text="Completa la informacion y agrega la inscripcion al carrito."
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>

                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 22"
                        BackgroundColor="{StaticResource TextPrimary}"
                        Padding="0">
                    <Grid RowDefinitions="Auto,Auto,Auto"
                          ColumnDefinitions="*,Auto"
                          Padding="16"
                          RowSpacing="12"
                          ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding EventName}"
                                   FontSize="18"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="White"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding EventInfoText}"
                                   FontSize="12"
                                   TextColor="#D7D0C1"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>

                        <Border Grid.Column="1"
                                Padding="10,6"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 13"
                                BackgroundColor="{StaticResource AccentSoft}"
                                VerticalOptions="Start">
                            <Label Text="{Binding EventPriceText}"
                                   FontSize="12"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource Accent}" />
                        </Border>

                        <BoxView Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 HeightRequest="1"
                                 Color="#3B372F"
                                 Opacity="0.75" />

                        <Grid Grid.Row="2"
                              Grid.ColumnSpan="2"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="1"
                                                 VerticalOptions="Center">
                                <Label Text="Dorsal asignado"
                                       FontSize="11"
                                       TextColor="#D7D0C1" />
                                <Label Text="{Binding CompetitorNumberText}"
                                       FontSize="32"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource Accent}" />
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    WidthRequest="76"
                                    HeightRequest="76"
                                    Stroke="#4B4538"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 38"
                                    BackgroundColor="#302C25">
                                <Grid>
                                    <Image Source="{Binding PhotoPath}"
                                           IsVisible="{Binding HasPhoto}"
                                           Aspect="AspectFill"
                                           WidthRequest="76"
                                           HeightRequest="76" />
                                    <Label Text="Foto"
                                           FontSize="12"
                                           TextColor="#D7D0C1"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="8">
                            <VerticalStackLayout Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="Buscar competidor"
                                       FontSize="16"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="Usa datos guardados si ya existe."
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="{Binding BrowseToggleButtonText, FallbackValue=Ver, TargetNullValue=Ver}"
                                    Command="{Binding ToggleBrowseCompetitorsCommand}"
                                    Style="{StaticResource OutlineButton}"
                                    MinimumWidthRequest="64" />
                            <Button Grid.Column="2"
                                    Text="Limpiar"
                                    Command="{Binding ClearSearchCommand}"
                                    Style="{StaticResource OutlineButton}"
                                    TextColor="{StaticResource Accent}"
                                    BorderColor="{StaticResource Accent}"
                                    MinimumWidthRequest="78" />
                        </Grid>

                        <Border HeightRequest="48"
                                Padding="10,0"
                                Stroke="{StaticResource HairLine}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16"
                                BackgroundColor="{StaticResource SurfaceSoft}">
                            <SearchBar Text="{Binding CompetitorSearchText}"
                                       SearchCommand="{Binding SearchCompetitorsCommand}"
                                       Placeholder="Cedula o nombre"
                                       BackgroundColor="Transparent"
                                       HeightRequest="46"
                                       Margin="-8,0" />
                        </Border>

                        <VerticalStackLayout Spacing="8"
                                             IsVisible="{Binding IsBrowseCompetitorsVisible}">
                            <Label Text="{Binding SelectedSavedSummaryText}"
                                   FontSize="12"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextSecondary}"
                                   IsVisible="{Binding HasSavedCompetitors}" />
                            <Label Text="No hay competidores guardados aun."
                                   FontSize="12"
                                   TextColor="{StaticResource TextMuted}"
                                   IsVisible="{Binding ShowEmptySavedCompetitorsHelp}" />
                            <CollectionView ItemsSource="{Binding SavedCompetitors}"
                                            HeightRequest="180"
                                            IsVisible="{Binding HasSavedCompetitors}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SelectableCompetitorItem">
                                        <Grid Padding="0,7"
                                              ColumnDefinitions="Auto,*"
                                              ColumnSpacing="6">
                                            <CheckBox VerticalOptions="Center"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding Competitor.FullName}"
                                                       FontSize="14"
                                                       FontFamily="OpenSansSemibold"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       MaxLines="1"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding Competitor.ProfileSummaryText}"
                                                       FontSize="11"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       MaxLines="2"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="10"
                                  IsVisible="{Binding HasSavedCompetitors}">
                                <Button Text="Inscribir"
                                        Command="{Binding AddSelectedToCartCommand}"
                                        IsEnabled="{Binding HasSelectedSavedCompetitors}"
                                        BackgroundColor="{StaticResource TextPrimary}"
                                        TextColor="White"
                                        FontSize="12"
                                        FontFamily="OpenSansSemibold"
                                        CornerRadius="13"
                                        HeightRequest="44" />
                                <Button Grid.Column="1"
                                        Text="Agregar y seguir"
                                        Command="{Binding AddSelectedAndContinueCommand}"
                                        IsEnabled="{Binding HasSelectedSavedCompetitors}"
                                        Style="{StaticResource OutlineButton}"
                                        TextColor="{StaticResource Accent}"
                                        BorderColor="{StaticResource Accent}"
                                        HeightRequest="44" />
                            </Grid>
                        </VerticalStackLayout>

                        <Label Text="No se encontraron competidores con esa busqueda."
                               IsVisible="{Binding HasSearchTextWithoutResults}"
                               FontSize="12"
                               TextColor="{StaticResource TextSecondary}" />

                        <VerticalStackLayout Spacing="8"
                                             IsVisible="{Binding HasSearchResults}"
                                             BindableLayout.ItemsSource="{Binding SearchResults}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 14"
                                            BackgroundColor="{StaticResource SurfaceSoft}">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="10">
                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="{Binding FullName}"
                                                       FontSize="14"
                                                       FontFamily="OpenSansSemibold"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       MaxLines="1"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding ProfileSummaryText}"
                                                       FontSize="11"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       MaxLines="1"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>

                                            <Button Grid.Column="1"
                                                    Text="Usar"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectCompetitorCommand}"
                                                    CommandParameter="{Binding}"
                                                    BackgroundColor="{StaticResource Accent}"
                                                    TextColor="White"
                                                    FontSize="12"
                                                    FontFamily="OpenSansSemibold"
                                                    CornerRadius="12"
                                                    HeightRequest="38"
                                                    Padding="12,0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Datos personales"
                                       FontSize="17"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="Informacion requerida para la inscripcion."
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="8"
                                                   VerticalOptions="Center">
                                <Button Text="Foto"
                                        Command="{Binding CapturePhotoCommand}"
                                        Style="{StaticResource OutlineButton}"
                                        TextColor="{StaticResource Accent}"
                                        BorderColor="{StaticResource Accent}"
                                        HeightRequest="40"
                                        Padding="12,0" />
                                <Button Text="+"
                                        Command="{Binding PickPhotoCommand}"
                                        BackgroundColor="{StaticResource AccentSoft}"
                                        TextColor="{StaticResource Accent}"
                                        BorderWidth="0"
                                        FontSize="18"
                                        FontFamily="OpenSansSemibold"
                                        CornerRadius="20"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        Padding="0" />
                            </HorizontalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Nombre completo"
                                   Style="{StaticResource FieldLabel}" />
                            <Border Style="{StaticResource FieldShell}">
                                <Entry Text="{Binding FullName}"
                                       Placeholder="Nombre del competidor"
                                       ClearButtonVisibility="WhileEditing"
                                       Style="{StaticResource FormEntry}" />
                            </Border>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Tipo documento"
                                       Style="{StaticResource FieldLabel}" />
                                <Border Style="{StaticResource FieldShell}">
                                    <Picker ItemsSource="{Binding DocumentTypes}"
                                            SelectedItem="{Binding SelectedDocumentType}"
                                            BackgroundColor="Transparent"
                                            FontSize="14"
                                            HeightRequest="46" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="6">
                                <Label Text="Documento"
                                       Style="{StaticResource FieldLabel}" />
                                <Border Style="{StaticResource FieldShell}">
                                    <Entry Text="{Binding DocumentNumber}"
                                           Placeholder="Numero"
                                           ClearButtonVisibility="WhileEditing"
                                           Style="{StaticResource FormEntry}" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Nacimiento"
                                       Style="{StaticResource FieldLabel}" />
                                <Border Style="{StaticResource FieldShell}">
                                    <DatePicker Date="{Binding BirthDate}"
                                                Format="dd MMM yyyy"
                                                BackgroundColor="Transparent"
                                                FontSize="14"
                                                HeightRequest="46" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="6">
                                <Label Text="Categoria"
                                       Style="{StaticResource FieldLabel}" />
                                <Border Style="{StaticResource FieldShell}">
                                    <Label Text="{Binding AgeText}"
                                           FontSize="13"
                                           TextColor="{StaticResource TextPrimary}"
                                           VerticalTextAlignment="Center"
                                           HeightRequest="46" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <Border IsVisible="{Binding HasStatusMessage}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource DangerSoft}"
                                Padding="12,10">
                            <Label Text="{Binding StatusMessage}"
                                   FontSize="12"
                                   TextColor="#B94A48"
                                   LineBreakMode="WordWrap" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Button Text="Volver a eventos"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextSecondary}"
                        FontFamily="OpenSansSemibold"
                        HeightRequest="42" />
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                Padding="16,12"
                StrokeThickness="0"
                BackgroundColor="#F8F7F2">
            <Border.Shadow>
                <Shadow Brush="#0A0A0A"
                        Opacity="0.08"
                        Radius="18"
                        Offset="0,-4" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="10">
                <Button Text="Agregar al carrito"
                        Command="{Binding AddToCartCommand}"
                        BackgroundColor="{StaticResource TextPrimary}"
                        TextColor="White"
                        FontFamily="OpenSansSemibold"
                        FontSize="14"
                        CornerRadius="14"
                        HeightRequest="50" />

                <Button Grid.Column="1"
                        Text="Otro"
                        Command="{Binding AddAnotherCommand}"
                        BackgroundColor="{StaticResource Surface}"
                        TextColor="{StaticResource Accent}"
                        BorderColor="{StaticResource Accent}"
                        BorderWidth="1"
                        FontFamily="OpenSansSemibold"
                        FontSize="13"
                        CornerRadius="14"
                        HeightRequest="50"
                        Padding="18,0" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
