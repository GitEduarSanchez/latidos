<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Latidos.Views.CartPage"
             Title="Carrito"
             BackgroundColor="#F7F7F5">

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="16,12"
          RowSpacing="14">

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <VerticalStackLayout Spacing="2">
                <Label Text="Carrito"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="#C9A227" />
                <Label Text="{Binding ItemCountText}"
                       FontSize="13"
                       TextColor="#777777"
                       IsVisible="{Binding HasItems}" />
            </VerticalStackLayout>

            <Border Grid.Column="1"
                    Stroke="#E8E3D5"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="White"
                    Padding="12,8"
                    VerticalOptions="Center"
                    IsVisible="{Binding HasItems}">
                <HorizontalStackLayout Spacing="7">
                    <Image Source="icon_cart.svg"
                           WidthRequest="18"
                           HeightRequest="18"
                           Aspect="AspectFit" />
                    <Label Text="{Binding ItemCount}"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#C9A227"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Border IsVisible="{Binding IsEmpty}"
                    Padding="24"
                    Stroke="#E8E3D5"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="White"
                    VerticalOptions="Center">
                <VerticalStackLayout Spacing="14"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Border WidthRequest="64"
                            HeightRequest="64"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 32"
                            BackgroundColor="#FFF7DB"
                            HorizontalOptions="Center">
                        <Image Source="icon_cart.svg"
                               WidthRequest="32"
                               HeightRequest="32"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <Label Text="Tu carrito esta vacio"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#252525"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Agrega una inscripcion desde eventos para verla aqui."
                           FontSize="13"
                           TextColor="#777777"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" />
                    <Button Text="Ver eventos"
                            Command="{Binding ContinueShoppingCommand}"
                            BackgroundColor="White"
                            TextColor="#C9A227"
                            BorderColor="#C9A227"
                            BorderWidth="1"
                            CornerRadius="10"
                            Padding="18,10"
                            FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>

            <CollectionView ItemsSource="{Binding CartItems}"
                            IsVisible="{Binding HasItems}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="0"
                               CornerRadius="14"
                               IsClippedToBounds="True"
                               HasShadow="True"
                               BorderColor="#E8E3D5"
                               BackgroundColor="White"
                               Margin="0">
                            <Grid RowDefinitions="96,Auto,Auto"
                                  RowSpacing="0">
                                <Image Grid.Row="0"
                                       Source="{Binding Event.ImageUrl}"
                                       Aspect="AspectFill"
                                       HeightRequest="96"
                                       HorizontalOptions="Fill"
                                       VerticalOptions="Fill" />

                                <Grid Grid.Row="1"
                                      ColumnDefinitions="*,Auto"
                                      Padding="16,14,16,6"
                                      ColumnSpacing="12">
                                    <VerticalStackLayout Spacing="5">
                                        <Label Text="{Binding Event.Name}"
                                               FontSize="17"
                                               FontAttributes="Bold"
                                               TextColor="#252525"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation" />
                                        <HorizontalStackLayout Spacing="6">
                                            <Image Source="icon_calendar.svg"
                                                   WidthRequest="14"
                                                   HeightRequest="14"
                                                   Aspect="AspectFit" />
                                            <Label Text="{Binding Event.EventDate, StringFormat='{0:dd MMM}'}"
                                                   FontSize="12"
                                                   TextColor="#777777"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <Button Grid.Column="1"
                                            Text="Quitar"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveFromCartCommand}"
                                            CommandParameter="{Binding}"
                                            BackgroundColor="White"
                                            TextColor="#B94A48"
                                            BorderColor="#F0C5C4"
                                            BorderWidth="1"
                                            CornerRadius="9"
                                            Padding="10,7"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            HeightRequest="36"
                                            MinimumWidthRequest="72" />
                                </Grid>

                                <Grid Grid.Row="2"
                                      ColumnDefinitions="*,Auto"
                                      Padding="16,4,16,16"
                                      ColumnSpacing="12">
                                    <HorizontalStackLayout Spacing="6"
                                                           VerticalOptions="Center">
                                        <Image Source="icon_users.svg"
                                               WidthRequest="14"
                                               HeightRequest="14"
                                               Aspect="AspectFit" />
                                        <Label Text="{Binding QuantityText}"
                                               FontSize="12"
                                               TextColor="#777777"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Grid.Column="1"
                                                           Spacing="6"
                                                           VerticalOptions="Center"
                                                           HorizontalOptions="End">
                                        <Image Source="icon_tag.svg"
                                               WidthRequest="15"
                                               HeightRequest="15"
                                               Aspect="AspectFit" />
                                        <Label Text="{Binding TotalPrice, StringFormat='${0:F2}'}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="#C9A227"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <Border Grid.Row="2"
                IsVisible="{Binding HasItems}"
                Padding="16"
                Stroke="#E8E3D5"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                BackgroundColor="White">
            <VerticalStackLayout Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Total"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#252525"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding CartTotal, StringFormat='${0:F2}'}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#C9A227"
                           VerticalOptions="Center" />
                </Grid>

                <Button Text="Finalizar compra"
                        Command="{Binding ProceedToCheckoutCommand}"
                        BackgroundColor="#C9A227"
                        TextColor="White"
                        Padding="15,12"
                        FontSize="14"
                        FontAttributes="Bold"
                        IsEnabled="{Binding CanCheckout}"
                        CornerRadius="10" />

                <Button Text="Continuar comprando"
                        Command="{Binding ContinueShoppingCommand}"
                        BackgroundColor="White"
                        TextColor="#C9A227"
                        Padding="15,12"
                        BorderWidth="1"
                        BorderColor="#C9A227"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="10" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
