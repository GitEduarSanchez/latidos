<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Latidos.Views.AdminEventsPage"
             Title="Admin">

    <ScrollView BackgroundColor="#F7F7F5">
        <VerticalStackLayout Padding="16,12,16,24"
                             Spacing="14">
            <VerticalStackLayout Spacing="2">
                <Label Text="Gestion de eventos"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="#C9A227" />
                <Label Text="{Binding EventsCountText}"
                       FontSize="12"
                       TextColor="#767676" />
            </VerticalStackLayout>

            <Border Padding="14"
                    Stroke="#E8E3D5"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="White">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Text="{Binding FormTitle}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#252525"
                               VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Text="Nuevo"
                                Command="{Binding NewEventCommand}"
                                BackgroundColor="White"
                                TextColor="#C9A227"
                                BorderColor="#C9A227"
                                BorderWidth="1"
                                FontSize="12"
                                FontAttributes="Bold"
                                CornerRadius="10"
                                HeightRequest="40"
                                Padding="12,0" />
                    </Grid>

                    <Label Text="Nombre"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#4F4F4F" />
                    <Border Padding="10,0"
                            Stroke="#E8E3D5"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="#FAFAFA">
                        <Entry Text="{Binding Name}"
                               Placeholder="Nombre del evento"
                               HeightRequest="44"
                               ClearButtonVisibility="WhileEditing" />
                    </Border>

                    <Label Text="Descripcion"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#4F4F4F" />
                    <Border Padding="10,0"
                            Stroke="#E8E3D5"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="#FAFAFA">
                        <Editor Text="{Binding Description}"
                                Placeholder="Resumen corto para la tarjeta"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="76" />
                    </Border>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Ciudad"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#4F4F4F" />
                            <Border Padding="10,0"
                                    Stroke="#E8E3D5"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="#FAFAFA">
                                <Entry Text="{Binding City}"
                                       Placeholder="Ciudad"
                                       HeightRequest="44"
                                       ClearButtonVisibility="WhileEditing" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Lugar"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#4F4F4F" />
                            <Border Padding="10,0"
                                    Stroke="#E8E3D5"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="#FAFAFA">
                                <Entry Text="{Binding Location}"
                                       Placeholder="Lugar"
                                       HeightRequest="44"
                                       ClearButtonVisibility="WhileEditing" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Fecha"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#4F4F4F" />
                            <Border Padding="10,0"
                                    Stroke="#E8E3D5"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="#FAFAFA">
                                <DatePicker Date="{Binding EventDate}"
                                            Format="dd MMM yyyy"
                                            HeightRequest="44" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Precio (COP)"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#4F4F4F" />
                            <Border Padding="10,0"
                                    Stroke="#E8E3D5"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="#FAFAFA">
                                <Entry Text="{Binding PriceText}"
                                       Placeholder="25000"
                                       Keyboard="Numeric"
                                       HeightRequest="44"
                                       ClearButtonVisibility="WhileEditing" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Capacidad"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#4F4F4F" />
                            <Border Padding="10,0"
                                    Stroke="#E8E3D5"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="#FAFAFA">
                                <Entry Text="{Binding MaxParticipantsText}"
                                       Placeholder="100"
                                       Keyboard="Numeric"
                                       HeightRequest="44"
                                       ClearButtonVisibility="WhileEditing" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Inscritos"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#4F4F4F" />
                            <Border Padding="10,0"
                                    Stroke="#E8E3D5"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="#FAFAFA">
                                <Entry Text="{Binding CurrentParticipantsText}"
                                       Placeholder="0"
                                       Keyboard="Numeric"
                                       HeightRequest="44"
                                       ClearButtonVisibility="WhileEditing" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Estado"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#4F4F4F" />
                            <Border Padding="10,0"
                                    Stroke="#E8E3D5"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="#FAFAFA">
                                <Picker ItemsSource="{Binding StatusOptions}"
                                        SelectedItem="{Binding SelectedStatusText}"
                                        HeightRequest="44" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Imagen"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#4F4F4F" />
                            <Border Padding="10,0"
                                    Stroke="#E8E3D5"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="#FAFAFA">
                                <Picker ItemsSource="{Binding ImageOptions}"
                                        SelectedItem="{Binding SelectedImageUrl}"
                                        HeightRequest="44" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <Button Text="{Binding PrimaryActionText}"
                            Command="{Binding SaveEventCommand}"
                            BackgroundColor="#C9A227"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="48" />

                    <Label Text="{Binding StatusMessage}"
                           IsVisible="{Binding HasStatusMessage}"
                           FontSize="12"
                           TextColor="#4F4F4F"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Eventos registrados"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#252525"
                   Margin="0,4,0,0" />

            <VerticalStackLayout Spacing="10"
                                 BindableLayout.ItemsSource="{Binding Events}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12"
                                Stroke="#E8E3D5"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="White">
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  RowSpacing="10">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="10">
                                    <VerticalStackLayout Spacing="3">
                                        <Label Text="{Binding Name}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="#252525"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding CityLocationText}"
                                               FontSize="12"
                                               TextColor="#767676"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>

                                    <Border Grid.Column="1"
                                            Padding="9,4"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10"
                                            BackgroundColor="{Binding StatusBackgroundColor}"
                                            VerticalOptions="Start">
                                        <Label Text="{Binding StatusText}"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="{Binding StatusTextColor}" />
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1"
                                      ColumnDefinitions="*,Auto"
                                      ColumnSpacing="10">
                                    <HorizontalStackLayout Spacing="6">
                                        <Image Source="icon_calendar.svg"
                                               WidthRequest="14"
                                               HeightRequest="14" />
                                        <Label Text="{Binding EventDate, StringFormat='{0:dd MMM yyyy}'}"
                                               FontSize="12"
                                               TextColor="#4F4F4F" />
                                    </HorizontalStackLayout>

                                    <Label Grid.Column="1"
                                           Text="{Binding PriceText}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#C9A227" />
                                </Grid>

                                <Grid Grid.Row="2"
                                      ColumnDefinitions="*,Auto,Auto"
                                      ColumnSpacing="8">
                                    <Label Text="{Binding CurrentParticipants, StringFormat='{0} inscritos'}"
                                           FontSize="12"
                                           TextColor="#767676"
                                           VerticalOptions="Center" />

                                    <Button Grid.Column="1"
                                            Text="Editar"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditEventCommand}"
                                            CommandParameter="{Binding}"
                                            BackgroundColor="White"
                                            TextColor="#C9A227"
                                            BorderColor="#C9A227"
                                            BorderWidth="1"
                                            CornerRadius="10"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            HeightRequest="40"
                                            Padding="12,0" />

                                    <Button Grid.Column="2"
                                            Text="Eliminar"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteEventCommand}"
                                            CommandParameter="{Binding}"
                                            BackgroundColor="#FDECEC"
                                            TextColor="#B42318"
                                            BorderColor="#F3B8B8"
                                            BorderWidth="1"
                                            CornerRadius="10"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            HeightRequest="40"
                                            Padding="12,0" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
